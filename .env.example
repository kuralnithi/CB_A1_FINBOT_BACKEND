# ─── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL_NAME=llama-3.1-8b-instant

# ─── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# ─── Qdrant (Vector Store) ────────────────────────────────────────────────────
QDRANT_HOST=https://your-qdrant-cluster.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# ─── Admin Bootstrap ─────────────────────────────────────────────────────────
ADMIN_USER=finbot_admin
ADMIN_PASS=ChangeThisPassword123!

# ─── LangSmith (Optional — for evaluation pipeline) ──────────────────────────
LANGCHAIN_API_KEY=ls_your_langsmith_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=finbot
